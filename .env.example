# Copy this file to ".env" and fill in your Supabase project values.
# In Supabase: Project Settings -> API.
# The service role key is SECRET — never expose it in the browser or commit it.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Real alerts to families (all optional) --------------------------------
# Public URL of the deployed site; used to link to the alert in the message.
APP_URL=https://your-app.vercel.app

# Email alerts via Resend (https://resend.com). ALERT_FROM_EMAIL must be on a
# domain you verified in Resend. Leave blank to disable email alerts.
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@your-domain.com

# SMS alerts via Twilio (https://twilio.com). TWILIO_FROM_NUMBER is your Twilio
# number in E.164 form, e.g. +15551234567. Leave blank to disable SMS alerts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Alerts page admin login (authorized personnel only) -------------------
# The Alerts page is restricted. To view it, an admin logs in with an email on
# this allowlist AND the shared password below. All three must be set or the
# Alerts page stays locked for everyone (fails closed).
# Comma-separated list of authorized admin emails.
ADMIN_EMAILS=admin@example.com
# Shared admin password — use a long, strong value.
ADMIN_PASSWORD=change-me-to-a-strong-password
# Secret that signs the admin session cookie. Generate a random one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string
