# Copy this file to ".env" and fill in your Supabase project values.
# In Supabase: Project Settings -> API.
# The service role key is SECRET — never expose it in the browser or commit it.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Real alerts to families (all optional) --------------------------------
# Public URL of the deployed site; used to link to the alert in the message.
APP_URL=https://your-app.vercel.app

# Email alerts via Resend (https://resend.com). ALERT_FROM_EMAIL must be on a
# domain you verified in Resend. Leave blank to disable email alerts.
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@your-domain.com

# SMS alerts via Twilio (https://twilio.com). TWILIO_FROM_NUMBER is your Twilio
# number in E.164 form, e.g. +15551234567. Leave blank to disable SMS alerts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
